# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is the public template.

# ---- S3-compatible object storage (required) ----
# Endpoint URL including scheme (http:// for local minio, https:// for cloud).
HETZNER_S3_ENDPOINT=https://your-region.your-objectstorage.example
HETZNER_S3_ACCESS_KEY=
HETZNER_S3_SECRET_KEY=
HETZNER_S3_BUCKET=your-bucket-here

# Object prefix where bronze parquet files are written.
# Must end with `/`. The writer also stages temp objects at <prefix>-tmp/.
BRONZE_S3_PREFIX=bronze/

# ---- Jetstream relay (required) ----
# Public Bluesky Jetstream WebSocket. The `/subscribe` path is appended by the writer.
JETSTREAM_URL=wss://jetstream2.us-east.bsky.network

# ---- Optional tuning (defaults shown) ----
# Number of events per parquet file. Smaller = more files, smoother memory; larger = fewer files, lower overhead.
# INGEST_BATCH_SIZE=100000

# Per-message receive timeout (seconds). When the WebSocket goes idle this long, the iter flushes and exits.
# INGEST_TIMEOUT_SECONDS=30

# Sleep between iterations of the outer main_loop. Each iter re-resolves the cursor from S3 LIST.
# BLUESKY_INGEST_SLEEP_SECONDS=60

# ---- bronze-status helper (optional, host-side) ----
# Path to the JSONL file the systemd-timer-driven bronze-status helper appends to.
# Only relevant if you've installed bronze-status; the writer itself does not read this.
# BRONZE_STATUS_LOG=/var/log/bronze-status.jsonl
